{
  "name": "create-collab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:next\" \"pnpm dev:hono\" --names \"NEXT,HONO\" --prefix-colors \"blue,green\"",
    "dev:next": "next dev",
    "dev:hono": "tsx watch src/index.ts",
    "dev:next-only": "next dev",
    "dev:hono-only": "tsx watch src/index.ts",
    "start:hono": "tsx src/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "db:generate:migration": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "open-auth-docs": "open-cli http://localhost:3000/api/auth/reference"
  },
